# EventBazaar .gitignore

# ----- Python backend -----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version

# Virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/

# Python tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.hypothesis/
.coverage
.coverage.*
htmlcov/

# ----- Frontend / Node -----
node_modules/
frontend/node_modules/
frontend/dist/
dist/
coverage/
.vite/
.next/
.nuxt/
.parcel-cache/
*.tsbuildinfo

# ----- Environment & secrets -----
.env
.env.*
!.env.example
backend/.env
frontend/.env
frontend/.env.*
secrets.json
credentials.json
config.local.json
*.pem
*.key
*.crt
*.p12
*.pfx

# ----- Logs and runtime -----
*.log
logs/
log/
*.pid
*.pid.lock

# ----- Uploads / generated assets -----
uploads/
media/
public/uploads/
backend/app/uploads/

# ----- Databases / dumps -----
*.db
*.sqlite
*.sqlite3
*.sql
*.dump

# ----- OS / editor -----
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.idea/
.vscode/
*.swp
*.swo
*~
